{
  "info": {
    "name": "Grid07 Assignment API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "url": "http://localhost:8080/api/users",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"john_doe\",\n  \"isPremium\": true\n}"
        }
      }
    },
    {
      "name": "Create Bot",
      "request": {
        "method": "POST",
        "url": "http://localhost:8080/api/bots",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Bot_5000\",\n  \"personaDescription\": \"I am a friendly bot\"\n}"
        }
      }
    },
    {
      "name": "Create Post",
      "request": {
        "method": "POST",
        "url": "http://localhost:8080/api/posts",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": \"PASTE_USER_UUID_HERE\",\n  \"authorType\": \"USER\",\n  \"content\": \"Hello this is my first post!\"\n}"
        }
      }
    },
    {
      "name": "Add Bot Comment",
      "request": {
        "method": "POST",
        "url": "http://localhost:8080/api/posts/PASTE_POST_UUID_HERE/comments",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": \"PASTE_BOT_UUID_HERE\",\n  \"authorType\": \"BOT\",\n  \"content\": \"Great post!\",\n  \"depthLevel\": 0,\n  \"humanUserId\": \"PASTE_USER_UUID_HERE\"\n}"
        }
      }
    },
    {
      "name": "Like Post",
      "request": {
        "method": "POST",
        "url": "http://localhost:8080/api/posts/PASTE_POST_UUID_HERE/like",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"PASTE_USER_UUID_HERE\",\n  \"authorType\": \"USER\"\n}"
        }
      }
    }
  ]
}